{
  "name": "mahjozly",
  "version": "1.0.0",
  "private": true,
  "description": "Mahjozly — open-source Cal.com-style scheduling + meeting platform with an AI session memory layer.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @mahjozly/backend",
    "dev:worker": "npm run dev -w @mahjozly/worker",
    "dev:frontend": "npm run dev -w @mahjozly/frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "npm run db:migrate -w @mahjozly/db",
    "db:studio": "npm run db:studio -w @mahjozly/db",
    "db:generate": "npm run db:generate -w @mahjozly/db",
    "db:seed": "npm run db:seed -w @mahjozly/db"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.20.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20"
  }
}
