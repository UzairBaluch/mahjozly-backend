# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=8001

DATABASE_URL=postgresql://user:password@localhost:5432/mahjozly

# Min 32 characters (see env.ts). Use a long random string in production.
JWT_SECRET=local-dev-only-replace-with-long-random-secret-32chars
JWT_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Must be a valid URL (used for CORS / links). Example for local frontend.
CLIENT_URL=http://localhost:3000
